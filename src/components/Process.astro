---
// Process.astro — 5-step timeline on dark background
---

<section id="proceso" class="section-padding" style="background-color: #0B1B32;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block text-xs font-bold tracking-widest uppercase mb-3" style="color: #B97333;">
        Metodología
      </span>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-4"
        style="letter-spacing: -0.02em;"
        data-i18n="process.title"
      >Cómo Funciona</h2>
      <p
        class="text-base max-w-2xl mx-auto"
        style="color: #8E9297;"
        data-i18n="process.subtitle"
      >Un proceso transparente y certificado de principio a fin</p>
    </div>

    <!-- Desktop: Horizontal Timeline -->
    <div class="hidden lg:block relative">
      <!-- Timeline connecting line -->
      <div class="absolute top-16 left-0 right-0 h-px px-16" aria-hidden="true">
        <div class="relative h-full" style="background: rgba(185,115,51,0.15);">
          <div class="timeline-line" aria-hidden="true"></div>
        </div>
      </div>

      <!-- Steps row -->
      <div class="grid grid-cols-5 gap-6 relative">

        <!-- Step 1 -->
        <div class="flex flex-col items-center text-center reveal stagger-1">
          <div
            class="relative z-10 w-14 h-14 rounded-full flex items-center justify-center mb-6 flex-shrink-0"
            style="background: linear-gradient(135deg, #B97333, #D4894A); box-shadow: 0 0 0 4px rgba(185,115,51,0.2);"
          >
            <!-- Icon: truck -->
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2 2h8l2-2zM13 16l1.5-3H18l2 2v1h-7z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div
            class="text-4xl font-black mb-2 leading-none"
            style="color: rgba(185,115,51,0.25);"
            data-i18n="process.steps.0.number"
          >01</div>
          <h3
            class="text-base font-bold text-white mb-2"
            data-i18n="process.steps.0.title"
          >Recolección</h3>
          <p
            class="text-xs leading-relaxed"
            style="color: #8E9297;"
            data-i18n="process.steps.0.desc"
          >Coordinamos el retiro de RAEE en tu instalación con flota propia y manifiestos de transporte certificados.</p>
        </div>

        <!-- Step 2 -->
        <div class="flex flex-col items-center text-center reveal stagger-2">
          <div
            class="relative z-10 w-14 h-14 rounded-full flex items-center justify-center mb-6 flex-shrink-0"
            style="background: linear-gradient(135deg, #B97333, #D4894A); box-shadow: 0 0 0 4px rgba(185,115,51,0.2);"
          >
            <!-- Icon: layers -->
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div
            class="text-4xl font-black mb-2 leading-none"
            style="color: rgba(185,115,51,0.25);"
            data-i18n="process.steps.1.number"
          >02</div>
          <h3
            class="text-base font-bold text-white mb-2"
            data-i18n="process.steps.1.title"
          >Clasificación</h3>
          <p
            class="text-xs leading-relaxed"
            style="color: #8E9297;"
            data-i18n="process.steps.1.desc"
          >Recepción, pesaje y categorización de equipos según tipo, composición y estado en nuestras instalaciones.</p>
        </div>

        <!-- Step 3 -->
        <div class="flex flex-col items-center text-center reveal stagger-3">
          <div
            class="relative z-10 w-14 h-14 rounded-full flex items-center justify-center mb-6 flex-shrink-0"
            style="background: linear-gradient(135deg, #B97333, #D4894A); box-shadow: 0 0 0 4px rgba(185,115,51,0.2);"
          >
            <!-- Icon: shield -->
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M20.618 5.984A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div
            class="text-4xl font-black mb-2 leading-none"
            style="color: rgba(185,115,51,0.25);"
            data-i18n="process.steps.2.number"
          >03</div>
          <h3
            class="text-base font-bold text-white mb-2"
            data-i18n="process.steps.2.title"
          >Pre-tratamiento</h3>
          <p
            class="text-xs leading-relaxed"
            style="color: #8E9297;"
            data-i18n="process.steps.2.desc"
          >Descontaminación, extracción segura de componentes peligrosos con protocolos certificados.</p>
        </div>

        <!-- Step 4 -->
        <div class="flex flex-col items-center text-center reveal stagger-4">
          <div
            class="relative z-10 w-14 h-14 rounded-full flex items-center justify-center mb-6 flex-shrink-0"
            style="background: linear-gradient(135deg, #B97333, #D4894A); box-shadow: 0 0 0 4px rgba(185,115,51,0.2);"
          >
            <!-- Icon: beaker/flask -->
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div
            class="text-4xl font-black mb-2 leading-none"
            style="color: rgba(185,115,51,0.25);"
            data-i18n="process.steps.3.number"
          >04</div>
          <h3
            class="text-base font-bold text-white mb-2"
            data-i18n="process.steps.3.title"
          >Valorización</h3>
          <p
            class="text-xs leading-relaxed"
            style="color: #8E9297;"
            data-i18n="process.steps.3.desc"
          >Separación y refinación de metales preciosos. Derivación a recicladores especializados según material.</p>
        </div>

        <!-- Step 5 -->
        <div class="flex flex-col items-center text-center reveal stagger-5">
          <div
            class="relative z-10 w-14 h-14 rounded-full flex items-center justify-center mb-6 flex-shrink-0"
            style="background: linear-gradient(135deg, #B97333, #D4894A); box-shadow: 0 0 0 4px rgba(185,115,51,0.2);"
          >
            <!-- Icon: document check -->
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div
            class="text-4xl font-black mb-2 leading-none"
            style="color: rgba(185,115,51,0.25);"
            data-i18n="process.steps.4.number"
          >05</div>
          <h3
            class="text-base font-bold text-white mb-2"
            data-i18n="process.steps.4.title"
          >Certificación</h3>
          <p
            class="text-xs leading-relaxed"
            style="color: #8E9297;"
            data-i18n="process.steps.4.desc"
          >Emisión de certificados de disposición final y reportes auditables para cumplimiento REP.</p>
        </div>

      </div>
    </div>

    <!-- Mobile: Vertical Timeline -->
    <div class="lg:hidden flex flex-col gap-0">

      {[
        {
          num: '01',
          titleKey: 'process.steps.0.title',
          descKey: 'process.steps.0.desc',
          defaultTitle: 'Recolección',
          defaultDesc: 'Coordinamos el retiro de RAEE en tu instalación con flota propia y manifiestos de transporte certificados.',
          icon: `<path d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z" stroke-linecap="round" stroke-linejoin="round"/><path d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10l2 2h8l2-2zM13 16l1.5-3H18l2 2v1h-7z" stroke-linecap="round" stroke-linejoin="round"/>`
        },
        {
          num: '02',
          titleKey: 'process.steps.1.title',
          descKey: 'process.steps.1.desc',
          defaultTitle: 'Clasificación',
          defaultDesc: 'Recepción, pesaje y categorización de equipos según tipo, composición y estado en nuestras instalaciones.',
          icon: `<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke-linecap="round" stroke-linejoin="round"/>`
        },
        {
          num: '03',
          titleKey: 'process.steps.2.title',
          descKey: 'process.steps.2.desc',
          defaultTitle: 'Pre-tratamiento',
          defaultDesc: 'Descontaminación, extracción segura de componentes peligrosos con protocolos certificados.',
          icon: `<path d="M20.618 5.984A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke-linecap="round" stroke-linejoin="round"/>`
        },
        {
          num: '04',
          titleKey: 'process.steps.3.title',
          descKey: 'process.steps.3.desc',
          defaultTitle: 'Valorización',
          defaultDesc: 'Separación y refinación de metales preciosos. Derivación a recicladores especializados según material.',
          icon: `<path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" stroke-linecap="round" stroke-linejoin="round"/>`
        },
        {
          num: '05',
          titleKey: 'process.steps.4.title',
          descKey: 'process.steps.4.desc',
          defaultTitle: 'Certificación',
          defaultDesc: 'Emisión de certificados de disposición final y reportes auditables para cumplimiento REP.',
          icon: `<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round"/>`
        },
      ].map((step, i) => (
        <div class={`flex gap-5 reveal stagger-${i + 1} pb-8 relative`}>
          <!-- Vertical line -->
          {i < 4 && (
            <div
              class="absolute left-6 top-14 bottom-0 w-px"
              style="background: linear-gradient(to bottom, rgba(185,115,51,0.4), rgba(185,115,51,0.1));"
              aria-hidden="true"
            ></div>
          )}
          <!-- Circle -->
          <div
            class="relative z-10 w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0"
            style="background: linear-gradient(135deg, #B97333, #D4894A); box-shadow: 0 0 0 3px rgba(185,115,51,0.2);"
          >
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" set:html={step.icon} />
          </div>
          <!-- Content -->
          <div class="pt-1">
            <div class="text-3xl font-black leading-none mb-1" style="color: rgba(185,115,51,0.25);">{step.num}</div>
            <h3 class="text-base font-bold text-white mb-1" data-i18n={step.titleKey}>{step.defaultTitle}</h3>
            <p class="text-sm leading-relaxed" style="color: #8E9297;" data-i18n={step.descKey}>{step.defaultDesc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

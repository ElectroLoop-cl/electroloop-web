---
// LanguageToggle.astro — Standalone language toggle button component
// Can be placed anywhere on the page as a standalone element.
// The main toggle logic lives in Navbar.astro and Layout.astro.
// This component is a convenience export if needed separately.
---

<div class="language-toggle-wrapper">
  <button
    id="lang-toggle-standalone"
    class="inline-flex items-center gap-1.5 text-xs font-bold border rounded-md px-3 py-1.5 transition-all duration-200"
    style="color: #8E9297; border-color: rgba(142,146,151,0.3);"
    aria-label="Cambiar idioma / Switch language"
    title="Cambiar idioma"
  >
    <!-- Globe icon -->
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <span id="lang-toggle-label">EN</span>
  </button>
</div>

<script>
  (function initStandaloneLangToggle() {
    const btn = document.getElementById('lang-toggle-standalone');
    const label = document.getElementById('lang-toggle-label');

    if (!btn || !label) return;

    // Set initial state
    const current = localStorage.getItem('electroloop-lang') || 'es';
    label.textContent = current === 'es' ? 'EN' : 'ES';

    btn.addEventListener('click', () => {
      const currentLang = localStorage.getItem('electroloop-lang') || 'es';
      const newLang = currentLang === 'es' ? 'en' : 'es';

      // Dispatch global event (Layout.astro listens for this)
      document.dispatchEvent(new CustomEvent('languagechange', { detail: newLang }));

      // Update label
      label.textContent = newLang === 'es' ? 'EN' : 'ES';

      // Sync all other toggle buttons
      ['lang-btn', 'lang-btn-mobile'].forEach((id) => {
        const b = document.getElementById(id);
        if (b) b.textContent = newLang === 'es' ? 'EN' : 'ES';
      });
    });

    // Listen for changes from other toggle buttons
    document.addEventListener('languagechange', (e: Event) => {
      const lang = (e as CustomEvent<string>).detail;
      if (label) label.textContent = lang === 'es' ? 'EN' : 'ES';
    });
  })();
</script>

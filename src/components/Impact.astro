---
// Impact.astro — 4 animated counter cards on dark gradient background
// <!-- PLACEHOLDER: reemplazar con datos reales -->
---

<section
  id="impacto"
  class="section-padding"
  style="background: linear-gradient(135deg, #071020 0%, #0B1B32 40%, #0d2240 70%, #071020 100%);"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section Header -->
    <div class="text-center mb-14 reveal">
      <span class="inline-block text-xs font-bold tracking-widest uppercase mb-3" style="color: #B97333;">
        Resultados
      </span>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl font-black text-white mb-4"
        style="letter-spacing: -0.02em;"
        data-i18n="impact.title"
      >Nuestro Impacto</h2>
      <p
        class="text-base max-w-xl mx-auto"
        style="color: #8E9297;"
        data-i18n="impact.subtitle"
      >Números que respaldan nuestro compromiso</p>
    </div>

    <!-- Counter Cards Grid -->
    <!-- PLACEHOLDER: reemplazar con datos reales -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <!-- Counter 1: Toneladas -->
      <div
        class="reveal stagger-1 rounded-2xl p-8 text-center border"
        style="background: rgba(255,255,255,0.04); border-color: rgba(185,115,51,0.2);"
      >
        <div class="flex items-end justify-center gap-1 mb-3">
          <span class="text-3xl font-black" style="color: #B97333;">+</span>
          <span
            class="text-5xl lg:text-6xl font-black text-white leading-none counter-value"
            data-counter="5000"
          >0</span>
        </div>
        <p
          class="text-sm font-medium"
          style="color: #8E9297;"
          data-i18n="impact.stats.0.label"
        >Toneladas procesadas</p>
        <div class="mt-4 h-px w-12 mx-auto" style="background: rgba(185,115,51,0.4);"></div>
      </div>

      <!-- Counter 2: Clientes -->
      <div
        class="reveal stagger-2 rounded-2xl p-8 text-center border"
        style="background: rgba(255,255,255,0.04); border-color: rgba(185,115,51,0.2);"
      >
        <div class="flex items-end justify-center gap-1 mb-3">
          <span class="text-3xl font-black" style="color: #B97333;">+</span>
          <span
            class="text-5xl lg:text-6xl font-black text-white leading-none counter-value"
            data-counter="150"
          >0</span>
        </div>
        <p
          class="text-sm font-medium"
          style="color: #8E9297;"
          data-i18n="impact.stats.1.label"
        >Clientes activos</p>
        <div class="mt-4 h-px w-12 mx-auto" style="background: rgba(185,115,51,0.4);"></div>
      </div>

      <!-- Counter 3: Trazabilidad % -->
      <div
        class="reveal stagger-3 rounded-2xl p-8 text-center border"
        style="background: rgba(255,255,255,0.04); border-color: rgba(185,115,51,0.2);"
      >
        <div class="flex items-end justify-center gap-1 mb-3">
          <span
            class="text-5xl lg:text-6xl font-black text-white leading-none counter-value"
            data-counter="99.5"
          >0</span>
          <span class="text-3xl font-black mb-1" style="color: #B97333;">%</span>
        </div>
        <p
          class="text-sm font-medium"
          style="color: #8E9297;"
          data-i18n="impact.stats.2.label"
        >Trazabilidad garantizada</p>
        <div class="mt-4 h-px w-12 mx-auto" style="background: rgba(185,115,51,0.4);"></div>
      </div>

      <!-- Counter 4: Materiales -->
      <div
        class="reveal stagger-4 rounded-2xl p-8 text-center border"
        style="background: rgba(255,255,255,0.04); border-color: rgba(185,115,51,0.2);"
      >
        <div class="flex items-end justify-center gap-1 mb-3">
          <span class="text-3xl font-black" style="color: #B97333;">+</span>
          <span
            class="text-5xl lg:text-6xl font-black text-white leading-none counter-value"
            data-counter="12"
          >0</span>
        </div>
        <p
          class="text-sm font-medium"
          style="color: #8E9297;"
          data-i18n="impact.stats.3.label"
        >Materiales recuperados</p>
        <div class="mt-4 h-px w-12 mx-auto" style="background: rgba(185,115,51,0.4);"></div>
      </div>

    </div>

    <!-- Context note -->
    <p
      class="text-center text-xs mt-8"
      style="color: rgba(142,146,151,0.5);"
    >
      Datos acumulados desde 2020. Actualización anual. <!-- PLACEHOLDER: reemplazar con datos reales -->
    </p>

  </div>
</section>

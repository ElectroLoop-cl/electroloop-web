---
// Chatbot.astro — Asistente virtual ElectroLoop
---

<!-- Chatbot container -->
<div id="chatbot-container" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">

  <!-- Chat window -->
  <div
    id="chat-window"
    class="hidden flex-col rounded-2xl overflow-hidden shadow-2xl"
    style="width: 320px; background: #0B1B32; border: 1px solid rgba(185,115,51,0.3);"
  >
    <!-- Header -->
    <div
      class="flex items-center justify-between px-4 py-3 flex-shrink-0"
      style="background: linear-gradient(135deg, #0d2444, #0B1B32); border-bottom: 1px solid rgba(185,115,51,0.2);"
    >
      <div class="flex items-center gap-3">
        <div
          class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0"
          style="background: rgba(185,115,51,0.2); border: 1px solid rgba(185,115,51,0.3);"
        >
          <svg class="w-4 h-4" fill="none" stroke="#B97333" stroke-width="2" viewBox="0 0 24 24">
            <path d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold text-white leading-tight">Claudio</p>
          <div class="flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
            <p class="text-xs" style="color: #8E9297;">En línea</p>
          </div>
        </div>
      </div>
      <button
        id="chat-close"
        class="w-7 h-7 flex items-center justify-center rounded-full transition-all duration-200 hover:bg-white/10"
        style="color: rgba(255,255,255,0.5);"
        aria-label="Cerrar chat"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Messages -->
    <div
      id="chat-messages"
      class="flex flex-col gap-3 p-4 overflow-y-auto"
      style="min-height: 280px; max-height: 340px;"
    ></div>

    <!-- Quick replies -->
    <div
      id="quick-replies"
      class="px-4 pb-4 flex flex-wrap gap-2"
    ></div>
  </div>

  <!-- Toggle button -->
  <button
    id="chat-toggle"
    class="w-14 h-14 rounded-full flex items-center justify-center shadow-lg transition-all duration-300 hover:scale-110 hover:shadow-xl"
    style="background: #B97333; box-shadow: 0 4px 20px rgba(185,115,51,0.4);"
    aria-label="Abrir asistente virtual"
  >
    <svg id="chat-icon-open" class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
    </svg>
    <svg id="chat-icon-close" class="w-6 h-6 text-white hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
</div>

<script>
  type Lang = 'es' | 'en';

  interface Option { text: string; id: string; }
  interface Response { text: string; options: Option[] | null; }

  const chatData: Record<Lang, {
    welcome: string;
    initialOptions: Option[];
    responses: Record<string, Response>;
  }> = {
    es: {
      welcome: '¡Hola! Soy Claudio, el asistente de ElectroLoop. ¿En qué puedo ayudarte hoy?',
      initialOptions: [
        { text: '¿Qué servicios ofrecen?', id: 'services' },
        { text: '¿Cómo funciona el proceso?', id: 'process' },
        { text: '¿Cuánto demora el retiro?', id: 'timing' },
        { text: '¿Qué es la Ley REP?', id: 'rep' },
        { text: 'Quiero contactarlos', id: 'contact' },
      ],
      responses: {
        services: {
          text: 'Ofrecemos tres servicios principales:\n\n• Recolección y destrucción de datos\n• Tratamiento y valorización de materiales\n• Gestión REP y reportería\n\n¿Sobre cuál quieres saber más?',
          options: [
            { text: 'Recolección y datos', id: 'svc_collection' },
            { text: 'Valorización', id: 'svc_recovery' },
            { text: 'Gestión REP', id: 'svc_rep' },
            { text: 'Volver', id: 'back' },
          ],
        },
        svc_collection: {
          text: 'Coordinamos el retiro de tus equipos directamente en tus instalaciones con flota propia. Cada dispositivo recibe borrado seguro de datos y recibes un certificado individual por cada equipo.',
          options: [
            { text: 'Ver todos los servicios', id: 'services' },
            { text: 'Agendar un retiro', id: 'contact' },
          ],
        },
        svc_recovery: {
          text: 'Desmontamos y clasificamos cada componente para recuperar metales como cobre, oro, plata y paladio. Los materiales regresan al ciclo productivo como materia prima secundaria.',
          options: [
            { text: 'Ver todos los servicios', id: 'services' },
            { text: 'Contactar', id: 'contact' },
          ],
        },
        svc_rep: {
          text: 'Gestionamos tu obligación REP de principio a fin: registro, reportería y documentación para el Ministerio del Medio Ambiente. Tú te concentras en tu negocio y nosotros cerramos el ciclo.',
          options: [
            { text: '¿Qué es la Ley REP?', id: 'rep' },
            { text: 'Contactar', id: 'contact' },
          ],
        },
        process: {
          text: 'El proceso tiene 6 pasos:\n\n1. Retiro en tus instalaciones\n2. Recepción y pesaje\n3. Destrucción de datos\n4. Desmantelamiento\n5. Valorización de materiales\n6. Certificado en tu correo\n\nTodo documentado y trazable.',
          options: [
            { text: '¿Cuánto demora?', id: 'timing' },
            { text: 'Agendar un retiro', id: 'contact' },
          ],
        },
        timing: {
          text: 'Coordinamos el retiro dentro de 48 a 72 horas de tu solicitud. El certificado final lo recibes dentro de 5 días hábiles.',
          options: [
            { text: 'Agendar un retiro', id: 'contact' },
            { text: 'Más preguntas', id: 'back' },
          ],
        },
        rep: {
          text: 'La Ley REP (N°20.920) obliga a productores e importadores a hacerse responsables del fin de vida de sus productos. ElectroLoop te ayuda a cumplir esta obligación de forma simple y documentada.',
          options: [
            { text: '¿Cómo me ayudan?', id: 'svc_rep' },
            { text: 'Contactar', id: 'contact' },
          ],
        },
        contact: {
          text: 'Puedes escribirnos a contacto@electroloop.cl o llenar el formulario de contacto en esta página. Te respondemos a la brevedad.',
          options: [
            { text: 'Ir al formulario', id: 'goto_form' },
            { text: 'Más preguntas', id: 'back' },
          ],
        },
        back: {
          text: '¿En qué más puedo ayudarte?',
          options: null,
        },
      },
    },
    en: {
      welcome: 'Hi! I\'m Claudio, the ElectroLoop assistant. How can I help you today?',
      initialOptions: [
        { text: 'What services do you offer?', id: 'services' },
        { text: 'How does the process work?', id: 'process' },
        { text: 'How long does pickup take?', id: 'timing' },
        { text: 'What is REP Law?', id: 'rep' },
        { text: 'I want to get in touch', id: 'contact' },
      ],
      responses: {
        services: {
          text: 'We offer three main services:\n\n• Collection & data destruction\n• Material treatment & recovery\n• REP management & reporting\n\nWhich would you like to know more about?',
          options: [
            { text: 'Collection & data', id: 'svc_collection' },
            { text: 'Recovery', id: 'svc_recovery' },
            { text: 'REP Management', id: 'svc_rep' },
            { text: 'Back', id: 'back' },
          ],
        },
        svc_collection: {
          text: 'We coordinate equipment pickup directly at your facilities using our own fleet. Each device receives secure data erasure and you get an individual certificate for every unit processed.',
          options: [
            { text: 'View all services', id: 'services' },
            { text: 'Schedule a pickup', id: 'contact' },
          ],
        },
        svc_recovery: {
          text: 'We dismantle and classify each component to recover metals like copper, gold, silver, and palladium. Materials re-enter the productive cycle as secondary raw materials.',
          options: [
            { text: 'View all services', id: 'services' },
            { text: 'Contact us', id: 'contact' },
          ],
        },
        svc_rep: {
          text: 'We manage your full REP obligation: registration, reporting and documentation for the Ministry of the Environment. You focus on your business and we close the loop.',
          options: [
            { text: 'What is REP Law?', id: 'rep' },
            { text: 'Contact us', id: 'contact' },
          ],
        },
        process: {
          text: 'Our process has 6 steps:\n\n1. Pickup at your premises\n2. Reception & weighing\n3. Data destruction\n4. Dismantling\n5. Material recovery\n6. Certificate in your inbox\n\nFully documented and traceable.',
          options: [
            { text: 'How long does it take?', id: 'timing' },
            { text: 'Schedule a pickup', id: 'contact' },
          ],
        },
        timing: {
          text: 'We coordinate pickup within 48 to 72 hours of your request. You receive the final certificate within 5 business days.',
          options: [
            { text: 'Schedule a pickup', id: 'contact' },
            { text: 'More questions', id: 'back' },
          ],
        },
        rep: {
          text: 'REP Law (N°20.920) requires producers and importers to take responsibility for the end-of-life of their products. ElectroLoop helps you comply simply and with full documentation.',
          options: [
            { text: 'How do you help?', id: 'svc_rep' },
            { text: 'Contact us', id: 'contact' },
          ],
        },
        contact: {
          text: 'You can write to us at contacto@electroloop.cl or fill out the contact form on this page. We\'ll get back to you shortly.',
          options: [
            { text: 'Go to contact form', id: 'goto_form' },
            { text: 'More questions', id: 'back' },
          ],
        },
        back: {
          text: 'What else can I help you with?',
          options: null,
        },
      },
    },
  };

  const toggle    = document.getElementById('chat-toggle')!;
  const chatWin   = document.getElementById('chat-window')!;
  const closeBtn  = document.getElementById('chat-close')!;
  const msgEl     = document.getElementById('chat-messages')!;
  const repliesEl = document.getElementById('quick-replies')!;
  const iconOpen  = document.getElementById('chat-icon-open')!;
  const iconClose = document.getElementById('chat-icon-close')!;

  let isOpen = false;
  let initialized = false;

  function getLang(): Lang {
    return (localStorage.getItem('electroloop-lang') || 'es') as Lang;
  }

  function addMessage(text: string, isBot = true) {
    const wrapper = document.createElement('div');
    wrapper.className = `flex ${isBot ? 'justify-start' : 'justify-end'} chat-msg`;
    wrapper.style.cssText = 'animation: fadeInUp 0.25s ease forwards; opacity: 0;';

    const bubble = document.createElement('div');
    bubble.style.cssText = isBot
      ? 'max-width:85%; background:rgba(255,255,255,0.07); color:rgba(255,255,255,0.9); border-radius:4px 16px 16px 16px; padding:10px 14px; font-size:13px; line-height:1.55;'
      : 'max-width:85%; background:#B97333; color:white; border-radius:16px 16px 4px 16px; padding:10px 14px; font-size:13px; line-height:1.55;';
    bubble.innerHTML = text.replace(/\n/g, '<br>');

    wrapper.appendChild(bubble);
    msgEl.appendChild(wrapper);
    msgEl.scrollTop = msgEl.scrollHeight;
  }

  function showTyping() {
    const t = document.createElement('div');
    t.id = 'typing-indicator';
    t.className = 'flex justify-start';
    t.innerHTML = `<div style="background:rgba(255,255,255,0.07); border-radius:4px 16px 16px 16px; padding:10px 14px;">
      <span style="display:flex;gap:4px;align-items:center;">
        <span style="width:6px;height:6px;border-radius:50%;background:#B97333;animation:bounceSlow 1s infinite 0s;display:inline-block;"></span>
        <span style="width:6px;height:6px;border-radius:50%;background:#B97333;animation:bounceSlow 1s infinite 0.2s;display:inline-block;"></span>
        <span style="width:6px;height:6px;border-radius:50%;background:#B97333;animation:bounceSlow 1s infinite 0.4s;display:inline-block;"></span>
      </span>
    </div>`;
    msgEl.appendChild(t);
    msgEl.scrollTop = msgEl.scrollHeight;
  }

  function removeTyping() {
    document.getElementById('typing-indicator')?.remove();
  }

  function showReplies(options: Option[]) {
    repliesEl.innerHTML = '';
    options.forEach(opt => {
      const btn = document.createElement('button');
      btn.textContent = opt.text;
      btn.style.cssText = 'background:rgba(185,115,51,0.12); color:#B97333; border:1px solid rgba(185,115,51,0.3); border-radius:999px; padding:5px 12px; font-size:12px; font-weight:600; cursor:pointer; transition:all 0.2s;';
      btn.onmouseenter = () => { btn.style.background = 'rgba(185,115,51,0.25)'; };
      btn.onmouseleave = () => { btn.style.background = 'rgba(185,115,51,0.12)'; };
      btn.addEventListener('click', () => handleOption(opt.id, opt.text));
      repliesEl.appendChild(btn);
    });
  }

  function handleOption(id: string, label: string) {
    const lang = getLang();
    const data = chatData[lang];

    if (id === 'goto_form') {
      document.getElementById('contacto')?.scrollIntoView({ behavior: 'smooth' });
      toggleChat();
      return;
    }

    repliesEl.innerHTML = '';
    addMessage(label, false);
    showTyping();

    setTimeout(() => {
      removeTyping();
      const resp = data.responses[id];
      if (!resp) return;
      addMessage(resp.text, true);
      const opts = resp.options ?? data.initialOptions;
      setTimeout(() => showReplies(opts), 300);
    }, 700);
  }

  function initChat() {
    if (initialized) return;
    initialized = true;
    msgEl.innerHTML = '';
    repliesEl.innerHTML = '';
    const data = chatData[getLang()];
    showTyping();
    setTimeout(() => {
      removeTyping();
      addMessage(data.welcome, true);
      setTimeout(() => showReplies(data.initialOptions), 400);
    }, 600);
  }

  function toggleChat() {
    isOpen = !isOpen;
    if (isOpen) {
      chatWin.classList.remove('hidden');
      chatWin.classList.add('flex');
      (chatWin as HTMLElement).style.flexDirection = 'column';
      iconOpen.classList.add('hidden');
      iconClose.classList.remove('hidden');
      initChat();
    } else {
      chatWin.classList.add('hidden');
      chatWin.classList.remove('flex');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    }
  }

  toggle.addEventListener('click', toggleChat);
  closeBtn.addEventListener('click', toggleChat);

  // Reset on language change so it re-initializes in new language
  document.addEventListener('languagechange', () => {
    if (isOpen) {
      initialized = false;
      initChat();
    } else {
      initialized = false;
    }
  });
</script>
